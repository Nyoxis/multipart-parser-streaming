{
  "name": "@nyoxis/multipart-parser-streaming",
  "version": "0.17.0",
  "description": "A fast, efficient parser for multipart streams in any JavaScript environment yielding parts as standard streams",
  "author": "Nyoxis <omicronnyoxis@gmail.com>",
  "contributors": [
    "Michael Jackson <mjijackson@gmail.com>"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nyoxis/multipart-parser-streaming.git"
  },
  "homepage": "https://github.com/Nyoxis/multipart-parser-streaming#readme",
  "bugs": {
    "url": "https://github.com/Nyoxis/multipart-parser-streaming/issues"
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./node": "./src/node.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "./node": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js"
      },
      "./package.json": "./package.json"
    }
  },
  "dependencies": {
    "@remix-run/headers": "^0.21.1"
  },
  "devDependencies": {
    "@remix-run/assert": "^0.2.1",
    "@remix-run/test": "^0.4.2",
    "@types/node": "^24.6.0",
    "@typescript/native-preview": "7.0.0-dev.20251125.1",
    "playwright": "^1.60.0"
  },
  "scripts": {
    "bench": "pnpm run bench:node && pnpm run bench:bun && pnpm run bench:deno",
    "bench:bun": "bun run ./bench/runner.ts",
    "bench:deno": "deno run --allow-sys ./bench/runner.ts",
    "bench:node": "node ./bench/runner.ts",
    "bench:node:single": "node ./bench/runner.ts",
    "bench:node:profile": "node --cpu-prof --heap-prof ./bench/runner.ts",
    "bench:node:steady": "node --expose-gc ./bench/runner.ts --steady --metrics",
    "build": "tsgo -p tsconfig.build.json",
    "clean": "git clean -fdX",
    "prepublishOnly": "pnpm run build",
    "test": "remix-test",
    "test:bun": "bun x --bun remix-test",
    "typecheck": "tsgo --noEmit"
  },
  "keywords": [
    "multipart",
    "parser",
    "stream",
    "http"
  ]
}
